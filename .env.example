# Smit AI Sahayak — Environment Variables
  # Copy this file to .env and fill in real values before starting the server

  # Port for the AI backend
  # Using 5001 to avoid conflict with smit-csc-info which runs on port 5000
  PORT=5001

  # PostgreSQL connection string (if using a database)
  DATABASE_URL=postgresql://user:password@localhost:5432/smit_sahayak

  # Google Gemini API key — get from https://aistudio.google.com/app/apikey
  GEMINI_API_KEY=your_gemini_api_key_here
  